record(waveform, "TBL:SFT:COL00") {
    field(FTVL, "INT64")
    field(NELM, "4")
    field(INP,  {const: [1, 2, 3] })
}

record(waveform, "TBL:SFT:COL01") {
    field(FTVL, "DOUBLE")
    field(NELM, "4")
    field(INP,  {const: [9.0, 8.0] })
}

record(waveform, "TBL:SFT:COL02") {
    field(FTVL, "STRING")
    field(NELM, "4")
}

record(table, "TBL:SFT") {
    field(MAXROWS, "4")

    field(C00INP, "TBL:SFT:COL00")
    field(C01INP, "TBL:SFT:COL01")
    field(C02INP, "TBL:SFT:COL02 CP")

    field(C00NAME, "x") field(C00LABEL, "X") field(C00TYPE, "INT64")
    field(C01NAME, "y") field(C01LABEL, "Y") field(C01TYPE, "DOUBLE")
    field(C02NAME, "z") field(C02LABEL, "Z") field(C02TYPE, "STRING")

    field(CO00NAME, "units")
    field(CO00TYPE, "STRING")
    field(CO00INP, {const: ["um", "um", "umstr"]})

    field(TPRO, "1")
    field(PINI, "YES")
}