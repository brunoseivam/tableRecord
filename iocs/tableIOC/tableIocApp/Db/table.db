record(waveform, "TBL:SFT:COL00") {
    field(FTVL, "INT64")
    field(NELM, "4")
    field(INP,  {const: [1, 2, 3] })
}

record(waveform, "TBL:SFT:COL01") {
    field(FTVL, "DOUBLE")
    field(NELM, "4")
    field(INP,  {const: [9.0, 8.0] })
}

record(waveform, "TBL:SFT:COL02") {
    field(FTVL, "STRING")
    field(NELM, "4")
}


record(table, "TBL:SFT") {
    field(MAXROWS, "4")

    field(COL00INP, "TBL:SFT:COL00")
    field(COL01INP, "TBL:SFT:COL01")
    field(COL02INP, "TBL:SFT:COL02 CP")

    field(COL00NAME, "x") field(COL00LABEL, "X") field(COL00TYPE, "INT64")
    field(COL01NAME, "y") field(COL01LABEL, "Y") field(COL01TYPE, "DOUBLE")
    field(COL02NAME, "z") field(COL02LABEL, "Z") field(COL02TYPE, "STRING")

    field(COLOPT00NAME, "units")
    field(COLOPT00TYPE, "STRING")
    field(COLOPT00INP, {const: ["um", "um", "umstr"]})

    field(TPRO, "1")
    field(PINI, "YES")
}