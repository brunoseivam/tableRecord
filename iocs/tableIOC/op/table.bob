      <x>5</x>
      <y>5</y>
      <width>690</width>
      <font>
        <font family="Liberation Sans" style="BOLD" size="18.0">
        </font>
      </font>
    </widget>
    <widget type="label" version="2.0.0">
      <name>Label_11</name>
      <text>Column labels and values are randomly generated in TBL:SRC, then stats are calculated in TBL:STAT</text>
      <x>5</x>
      <y>25</y>
      <width>690</width>
    </widget>
    <widget type="table" version="2.0.0">
      <name>Table_4</name>
      <pv_name>pva://TBL:SRC</pv_name>
      <x>5</x>
      <y>45</y>
      <width>790</width>
      <height>550</height>
      <columns>
        <column>
          <name>Column 1</name>
          <width>100</width>
